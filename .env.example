# ==============================================================================
# FEEDLINK AI - MASTER ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================

# --- Spring Boot Backend Gateway Config ---
PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://<database-host>:<port>/<database-name>?sslmode=require
SPRING_DATASOURCE_USERNAME=<db-username>
SPRING_DATASOURCE_PASSWORD=<db-password>
JWT_SECRET=<min-32-char-jwt-secret-key>
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
FASTAPI_URL=http://localhost:8000

# --- Optional SMTP Mail Integration ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@feedlink.ai

# --- FastAPI AI Microservice Config ---
AI_PORT=8000
GEMINI_API_KEY=<your-google-gemini-flash-api-key>
MONGO_URI=mongodb://localhost:27017
CLOUDINARY_URL=

# --- React Frontend Config ---
VITE_API_BASE_URL=http://localhost:8080
